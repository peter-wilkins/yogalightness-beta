---
import "../styles/global.css";
import "../styles/themes.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yoga Lightness Beta",
  description = "A public beta rebuild of Yoga Lightness for Jane to review.",
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav aria-label="Primary">
        <a class="brand" href={base}>Yoga Lightness Beta</a>
        <div class="nav-links">
          <a href={`${base}blog/`}>Posts</a>
          <a href={`${base}source-map/`}>Source Map</a>
          <a href={`${base}theme-preview/`}>Themes</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Public beta rebuild from <a href="https://www.yogalightness.com/">yogalightness.com</a>.
        Full content migration should wait for Jane's review.
      </p>
    </footer>
  </body>
</html>
