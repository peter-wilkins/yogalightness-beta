---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const sourcePages = [
  {
    title: "Home",
    url: "https://www.yogalightness.com/",
    note: "Current public landing page for Yoga Lightness.",
  },
  {
    title: "About Jane",
    url: "https://www.yogalightness.com/aboutme/",
    note: "Teacher background, practice history, and Yasodhara Yoga context.",
  },
  {
    title: "Classes",
    url: "https://www.yogalightness.com/classes/",
    note: "Classes, workshops, Reiki treatments, and contact-led updates.",
  },
  {
    title: "Yasodhara Yoga",
    url: "https://www.yogalightness.com/yasodhara/",
    note: "Reflective yoga overview and spiritual lineage material.",
  },
  {
    title: "What is Kundalini?",
    url: "https://www.yogalightness.com/2017-11-22-kundalini/",
    note: "Published article summarised in the beta blog.",
  },
  {
    title: "The origins of the Divine Light Invocation",
    url: "https://www.yogalightness.com/2017-10-18-divine/",
    note: "Published article summarised in the beta blog.",
  },
];

const imageAssets = [
  "profile-2024.jpg",
  "lightning.jpg",
  "lotus.jpg",
  "meditation.jpg",
  "chakra.jpg",
  "light.png",
  "radha.jpg",
];
---

<BaseLayout title="Yoga Lightness Source Map" description="Scraped source map for the Yoga Lightness beta rebuild.">
  <section class="page-title">
    <p class="eyebrow">Scraped Source Map</p>
    <h1>What The Beta Found</h1>
    <p class="lede">
      Public pages and assets discovered from the Yoga Lightness sitemap, feed,
      and page markup.
    </p>
  </section>

  <section class="post-list">
    {sourcePages.map((page) => (
      <article class="post-card">
        <a href={page.url}>
          <span class="status">Original page</span>
          <h2>{page.title}</h2>
          <p>{page.note}</p>
        </a>
      </article>
    ))}
  </section>

  <section class="section">
    <h2>Imported Image Assets</h2>
    <div class="asset-grid">
      {imageAssets.map((asset) => (
        <figure>
          <img src={`${base}source-assets/${asset}`} alt="" />
          <figcaption>{asset}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Migration Decision Still Needed</h2>
    <p>
      This beta publishes summaries and links. A full mirror of Yoga Lightness
      article bodies should wait until Jane confirms that the content should be
      migrated into the new public repo.
    </p>
  </section>
</BaseLayout>
