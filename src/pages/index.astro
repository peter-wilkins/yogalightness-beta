---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Yoga Lightness Beta" description="A public beta rebuild of Yoga Lightness for Jane to review.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Public Review Build</p>
      <h1>Yoga Lightness</h1>
      <p class="lede">
        A light, modern review site for Jane's yoga teaching, reflective practice,
        and existing writing at Yoga Lightness.
      </p>
      <div class="button-row">
        <a class="button" href={`${base}blog/`}>Read posts</a>
        <a class="button secondary" href={`${base}source-map/`}>See source map</a>
      </div>
    </div>
    <figure class="hero-media">
      <img src={`${base}source-assets/profile-2024.jpg`} alt="Yoga Lightness profile portrait" />
    </figure>
  </section>

  <section class="section">
    <h2>What This Is</h2>
    <p>
      This is a fast public beta, built from the public Yoga Lightness sitemap and feed.
      It preserves the important paths and gives Jane a live place to review structure,
      tone, and next edits before any full migration happens.
    </p>
  </section>

  <section class="feature-grid" aria-label="Main source areas">
    <article>
      <img src={`${base}source-assets/light.png`} alt="" />
      <h2>Reflective Practice</h2>
      <p>Clear routes into Hidden Language, Kundalini, Divine Light, and Yasodhara Yoga.</p>
    </article>
    <article>
      <img src={`${base}source-assets/meditation.jpg`} alt="" />
      <h2>Classes And Workshops</h2>
      <p>A cleaner home for current classes, workshops, Reiki, and contact details.</p>
    </article>
    <article>
      <img src={`${base}source-assets/radha.jpg`} alt="" />
      <h2>Lineage</h2>
      <p>Space for Yasodhara Yoga context and the lineage material already on the site.</p>
    </article>
  </section>

  <section class="section split">
    <div>
      <h2>Review Notes</h2>
      <p>
        The beta deliberately uses summaries and source links rather than a full content
        mirror. Once Jane confirms ownership and preferred wording, the site can migrate
        full article bodies and simplify the old Jekyll site into this structure.
      </p>
    </div>
    <div class="note-panel">
      <p class="eyebrow">Found In Source</p>
      <p>2 articles, 3 standing pages, RSS feed, sitemap, and 7 reusable image assets.</p>
    </div>
  </section>
</BaseLayout>
