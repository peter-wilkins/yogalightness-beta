---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Still Ground in North Norfolk</p>
      <h1>Still Ground</h1>
      <p class="lede">
        One-to-one contemplative support, spacious personal retreats, and The
        Retreat, a tiny solo cabin for people who need time to breathe, listen, and
        return to themselves. Jane also offers meditation days and a free local
        Awakening Dignity practice group in Aylsham.
      </p>
      <div class="button-row">
        <a class="button" href={`${base}day-retreat/`}>One-day retreat</a>
        <a class="button secondary" href={`${base}work-with-jane/`}>Work with Jane</a>
      </div>
    </div>
    <figure class="hero-media">
      <img
        src={`${base}assets/retreat-cottage/retreat-cottage-exterior.webp`}
        alt="The brick exterior of The Retreat beside the garden"
        width="1800"
        height="1350"
        decoding="async"
      />
      <figcaption>The Retreat</figcaption>
    </figure>
  </section>

  <section class="statement" aria-label="Core promise">
    <p>
      Sometimes what we need most is not advice, diagnosis, or a programme to
      follow. It is simply to be heard deeply, without judgement, by someone who
      knows how to hold space.
    </p>
  </section>

  <section class="offer-grid" aria-label="Current offerings">
    <article>
      <p class="small-label">Saturday 4 July</p>
      <h3>A day of meditation and relaxation</h3>
      <p>
        A small, nourishing day in Aylsham with meditation, gentle accessible
        yoga, breathing practices, Yoga Nidra, vegan lunch, refreshments, and
        spacious time to rest.
      </p>
      <a href={`${base}day-retreat/`}>Read the day retreat details</a>
    </article>
    <article>
      <p class="small-label">Private weekend</p>
      <h3>Learn to meditate</h3>
      <p>
        A private, structured weekend introduction in Aylsham for one guest:
        Buddhist-informed, personal, and suitable for complete beginners.
      </p>
      <a href={`${base}learn-to-meditate/`}>See the meditation weekend</a>
    </article>
    <article>
      <p class="small-label">Free weekly group</p>
      <h3>Awakening Dignity practice group</h3>
      <p>
        A six-month Monday morning journey into dignity, compassion, meditation,
        contemplation, and meaningful connection. Available in Aylsham and
        online.
      </p>
      <a href={`${base}awakening-dignity/`}>Explore the practice group</a>
    </article>
  </section>

  <section class="section section-narrow">
    <p class="eyebrow">With JaneCatherine Aldiss</p>
    <h2>Presence without performance</h2>
    <p>
      Jane brings more than forty years of lived practice across yoga,
      meditation, Shiatsu, Reiki, dreamwork, Non Violent Communication, deep
      listening, and compassionate companionship. Her work is personal,
      unhurried, and grounded in the real texture of being human.
    </p>
  </section>

  <section class="feature-grid" aria-label="Ways to work with Jane">
    <article>
      <p class="small-label">One-to-one</p>
      <h3>Wellbeing and clarity</h3>
      <p>
        Spacious online or in-person sessions for stress, overwhelm, grief,
        transition, or simply needing somewhere honest to speak and be heard.
      </p>
    </article>
    <article>
      <p class="small-label">Immersive</p>
      <h3>Private weekends</h3>
      <p>
        Personal retreats and a structured learn-to-meditate weekend, both
        private and held one guest at a time in Aylsham.
      </p>
    </article>
    <article>
      <p class="small-label">Solo practice</p>
      <h3>The Retreat</h3>
      <p>
        A tiny, self-catering practice cabin near Aylsham for solo retreat
        stays of 5 to 28 nights.
      </p>
    </article>
  </section>

  <section class="retreat-feature">
    <div class="soft-panel">
      <p class="eyebrow">The personal retreat</p>
      <h2>A weekend shaped around spaciousness</h2>
      <p>
        One guest at a time. A few gentle anchor points create rhythm, while most
        of the weekend remains yours: walking, resting, journaling, sleeping, or
        doing absolutely nothing.
      </p>
      <a class="button" href={`${base}personal-retreats/`}>Explore personal retreats</a>
    </div>
    <figure class="retreat-image">
      <img
        src={`${base}assets/held-space-placeholder.webp`}
        alt="A calm retreat room with a meditation cushion and soft natural light"
      />
      <figcaption>Visual direction placeholder</figcaption>
    </figure>
  </section>

  <section class="split">
    <div>
      <p class="eyebrow">The Retreat</p>
      <h2>Tiny, private, and intentionally simple</h2>
      <p>
        A tiny private cabin in rural Norfolk for solo retreat guests. It is
        small by design: a contained, quiet, self-catering place for sitting,
        simplifying, and being with practice.
      </p>
      <a class="button secondary" href={`${base}retreatcottage/`}>See retreat details</a>
    </div>
    <div class="note-panel">
      <p class="small-label">Practical</p>
      <p>Solo guests only. Minimum 5 nights, maximum 28 nights.</p>
      <p>No WiFi, no TV, and limited mobile signal at the top of the garden.</p>
      <p>Near Itteringham, Blickling Hall, Aylsham, and the North Norfolk coast.</p>
    </div>
  </section>

  <section class="contact-band" id="contact">
    <div>
      <p class="eyebrow">Begin gently</p>
      <h2>A free 20-minute introductory call is available</h2>
      <p>No preparation needed. Just come as you are.</p>
    </div>
    <a class="button" href="mailto:hello@stillground.co.uk">Email Jane</a>
  </section>
</BaseLayout>
